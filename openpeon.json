{
  "cesp_version": "1.0",
  "name": "stronghold-nizar",
  "display_name": "Nizar (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/ni_add_player_01.wav", "label": "Take care" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/ni_willattack_01.wav", "label": "Yes" },
        { "file": "sounds/ni_sent_01.wav", "label": "Generous this time" },
        { "file": "sounds/ni_siege_01.wav", "label": "Black mist will engulf" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/ni_vict_04.wav", "label": "I have silenced another" },
        { "file": "sounds/ni_boast_01.wav", "label": "One less enemy" },
        { "file": "sounds/ni_vict_02.wav", "label": "Watch your castle fall" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/ni_anger_01.wav", "label": "Do not escape your fate" },
        { "file": "sounds/ni_anger_02.wav", "label": "We will grow another foot" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/ni_help_01.wav", "label": "Help me now" },
        { "file": "sounds/ni_req_01.wav", "label": "I need supplies" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/ni_notsent_01.wav", "label": "Last crumbs from my plate" },
        { "file": "sounds/ni_noattack_01.wav", "label": "Will not throw away lives" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/ni_nervous_01.wav", "label": "Watch your back, fool" },
        { "file": "sounds/ni_kick_player_01.wav", "label": "Gone" }
      ]
    }
  }
}
